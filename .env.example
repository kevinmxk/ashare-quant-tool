# provider options: auto / akshare / sina / tushare / baostock / mock
ASHARE_QUANT_PROVIDER=auto
ASHARE_QUANT_RANKING_LIMIT=20
ASHARE_QUANT_USE_MOCK_WHEN_PROVIDER_FAILS=true
ASHARE_QUANT_PROVIDER_CACHE_TTL_SECONDS=15
ASHARE_QUANT_TUSHARE_TOKEN=
ASHARE_QUANT_PERSISTENT_CACHE_ENABLED=true
ASHARE_QUANT_PERSISTENT_CACHE_PATH=data/cache/market_cache.sqlite3
ASHARE_QUANT_PERSISTENT_QUOTE_TTL_SECONDS=900
ASHARE_QUANT_PERSISTENT_BAR_TTL_SECONDS=43200
ASHARE_QUANT_PERSISTENT_CACHE_ALLOW_STALE_ON_ERROR=true
